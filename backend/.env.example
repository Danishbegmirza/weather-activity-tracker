# Server Configuration
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# CORS Configuration
# Comma-separated list of allowed origins (use * for all in development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=false

# Rate Limiting
# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
# TTL in seconds (default: 1800 = 30 minutes)
CACHE_TTL_SECONDS=1800
# Max entries before LRU eviction (default: 1000)
CACHE_MAX_ENTRIES=1000

# Open-Meteo API Configuration (optional - defaults to public endpoints)
# OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
# OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# OPEN_METEO_MARINE_URL=https://marine-api.open-meteo.com/v1/marine
OPEN_METEO_MAX_SEARCH_RESULTS=10
OPEN_METEO_FORECAST_DAYS=7
# Request timeout in milliseconds (default: 10000 = 10s)
OPEN_METEO_TIMEOUT_MS=10000
# Max retry attempts (default: 2)
OPEN_METEO_MAX_RETRIES=2
# Retry delay in milliseconds (default: 1000 = 1s)
OPEN_METEO_RETRY_DELAY_MS=1000
